{
    "version": 2,
    "framework": null,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.6.2",
            "config": {
                "includeFiles": ["public/**", "public/build/**"]
            }
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "headers": [
        {
            "source": "/build/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/build/manifest.json",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        },
        {
            "source": "/(.+).ttf",
            "headers": [
                { "key": "Content-Type", "value": "font/truetype" },
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/(.+).woff",
            "headers": [
                { "key": "Content-Type", "value": "font/woff" },
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/(.+).woff2",
            "headers": [
                { "key": "Content-Type", "value": "font/woff2" },
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        }
    ],

    "rewrites": [
        {
            "source": "/build/assets/(.*)",
            "destination": "/public/build/assets/$1"
        },
        {
            "source": "/build/manifest.json",
            "destination": "/public/build/manifest.json"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.php?__path_override=api/$1"
        },
        {
            "source": "/favicon.ico",
            "destination": "/public/favicon.ico"
        },
        {
            "source": "/images/(.*)",
            "destination": "/public/images/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.php?__path_override=$1"
        }
    ]
}
